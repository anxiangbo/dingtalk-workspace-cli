      ],
      "effect": "read",
      "effect_source": "command-verb",
      "examples": [
        "dws contact user get --ids userId1,userId2"
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
    },
    "contact user get-self": {
      "use_when": [
        "1. 查看自己的信息 — 提取 userId",
