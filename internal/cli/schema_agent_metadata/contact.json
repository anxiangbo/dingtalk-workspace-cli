      "effect": "read",
      "effect_source": "command-verb",
      "examples": [
        "dws contact user search --query \"张三\"",
        "dws contact user search --query \"张三\" --format json"
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
    },
    "contact user search-mobile": {
      "examples": [
        "dws contact user search-mobile --mobile 13800138000"
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
