      "effect": "read",
      "effect_source": "command-verb",
      "examples": [
        "dws contact user profile get --staff-id STAFF_ID",
        "dws contact user profile get --staff-id STAFF_ID --fields fieldCode1,fieldCode2"
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
