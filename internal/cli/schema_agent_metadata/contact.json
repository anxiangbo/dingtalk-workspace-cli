{
  "product_id": "contact",
  "tools": {
    "contact dept get-info": {
      "use_when": [
        "4. 查看部门详情（部门ID、名称、人数）",
        "部门详情/部门信息/部门多少人"
      ],
      "effect": "read",
      "effect_source": "command-verb",
      "examples": [
        "dws contact dept get-info --dept 12345",
        "dws contact dept get-info --dept \u003cdeptId\u003e --format json"
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
    },
    "contact dept list-children": {
      "use_when": [
        "5. 查看直属子部门 — 提取子 deptId 列表",
        "子部门/下设部门/部门有哪些下级部门/枚举二级部门"
      ],
      "effect": "read",
      "effect_source": "command-verb",
      "examples": [
        "dws contact dept list-children --dept 1           # 枚举根部门下的一级部门",
        "dws contact dept list-children --dept 12345       # 枚举指定部门的直属子部门"
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
    },
    "contact dept list-members": {
      "use_when": [
        "6. 查看部门成员",
        "部门有谁/部门成员/人员名单"
      ],
      "effect": "read",
      "effect_source": "command-verb",
      "examples": [
        "dws contact dept list-members --depts 1              # 根部门",
        "dws contact dept list-members --depts 12345,67890"
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
    },
    "contact dept search": {
      "use_when": [
        "3. 查看部门结构 — 提取 deptId",
        "找部门/哪个部门"
      ],
      "effect": "read",
      "effect_source": "command-verb",
      "examples": [
        "dws contact dept search --query \"技术部\"",
        "dws contact dept search --query \"技术部\" --format json"
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
    },
    "contact relation list-my-followings": {
      "use_when": [
        "我关注了谁/我的特别关注列表/我的星标联系人/特别关注的人有哪些"
      ],
      "effect": "read",
      "effect_source": "command-verb",
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
    },
    "contact user dismission search": {
      "use_when": [
        "13. 查询全部离职员工",
        "14. 按姓名/时间范围/部门筛选离职员工",
        "离职员工/离职名单/离职人员/已离职"
      ],
      "effect": "read",
      "effect_source": "command-verb",
      "examples": [
        "dws contact user dismission search",
        "dws contact user dismission search --name \"张三\""
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
    },
    "contact user get": {
      "use_when": [
