      "effect": "read",
      "effect_source": "command-verb",
      "examples": [
        "dws contact user get-self",
        "dws contact user get-self --format json"
      ],
      "source_refs": [
        "skills/mono/references/products/contact.md"
      ]
    },
    "contact user profile fields": {
      "use_when": [
        "10. 查询花名册有权限的字段列表",
        "花名册字段/有哪些字段/字段列表"
